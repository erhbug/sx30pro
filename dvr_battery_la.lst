 798          /**
 799            ******************************************************************************
 800            * Objetivo: Enviar informacion del control de carga a traves del puerto serial
 801            * Parametros entrada: Ninguno
 802                  */
 803          void vSend_Data_Cargador(unsigned char bStatus_Volt){
 804                  
 805                  char cData_Serial[20];
 806                          
 807                  vSend_String_USB(" Vb: ");      
 808                  sprintf(cData_Serial, "%6.3f", fVoltage_Battery);
 809                  vSend_String_USB(cData_Serial); 
 810                  
 811                  vSend_String_USB(" Vc: ");      
 812                  sprintf(cData_Serial, "%6.3f", fVoltage_Conector);
 813                  vSend_String_USB(cData_Serial);
 814                  
 815                  vSend_String_USB(" Vr: ");      
 816                  sprintf(cData_Serial, "%6.3f ", fVoltage_Ref*100);
 817                  vSend_String_USB(cData_Serial);
 818                  
 819                  switch(bStatus_Volt){
 820                          
 821                          case SOURCE_ADAPTER:
 822                                  vSend_String_USB("SOURCE_ADAPTER");
 823                                  break;
 824                                  
 825                          case SOURCE_BATTERY_OK:
 826                                  vSend_String_USB("SOURCE_BATTERY_OK");
 827                                  break;
 828                          
 829                          case SOURCE_BATTERY_HIGH:                                       
 830                                  vSend_String_USB("SOURCE_BATTERY_HIGH");
 831                                  break;
 832                          
 833                          case SOURCE_BATTERY_LOW:
 834                                  vSend_String_USB("SOURCE_BATTERY_LOW");
 835                                  break;
 836                                  
 837                          case SOURCE_BATTERY_VERY_LOW:
 838                                  vSend_String_USB("SOURCE_BATTERY_VERY_LOW");
 839                                  break;
 840                                  
 841                          case SOURCE_ADAPTER_HIGH:
 842                                  vSend_String_USB("SOURCE_ADAPTER_HIGH");
 843                                  break;
 844                                  
 845                          case SOURCE_BAD_BATTERY:
 846                                  vSend_String_USB("SOURCE_BAD_BATTERY");
 847                                  break;
 848                  }
C51 COMPILER V7.50   DVR_BATTERY_LA                                                        09/12/2022 23:28:44 PAGE 15  

 849                  
 850                  vSend_String_USB("\n\r");
 851          }

