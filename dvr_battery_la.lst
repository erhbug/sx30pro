 688          /**
 689            ******************************************************************************
 690            * Objective: To obtain the value of the channel ADC.
 691                  ******************************************************************************
 692                  */
 693          uint16_t iGet_ADCx_Value(uint32_t *iVectorConv, unsigned char iSampleNumber){
 694                  unsigned char j = 0;
 695                  uint32_t iVectorConvAcc[4]= {0};
 696                  uint32_t tickstart = 0;
 697                  uint32_t Timeout = 10;
 698                          
 699                  for(j=0;j<iSampleNumber;j++){
 700                          
 701                          
 702                          HAL_ADC_Start(&hadc);
 703                          tickstart = HAL_GetTick();
 704                          IWDG->KR =  IWDG_KEY_REFRESH;           
 705                          while(__HAL_ADC_GET_FLAG(&hadc, ADC_FLAG_EOC) == RESET){
 706                                  if((HAL_GetTick()-tickstart) >= Timeout){
 707                                          return 1;
 708                                  }
 709                                  IWDG->KR = IWDG_KEY_REFRESH;
 710                          }               
 711                          iVectorConvAcc[1] += HAL_ADC_GetValue(&hadc);   
 712          
 713                          tickstart = HAL_GetTick();                      
 714                          IWDG->KR =  IWDG_KEY_REFRESH;           
 715                          while(__HAL_ADC_GET_FLAG(&hadc, ADC_FLAG_EOC) == RESET)
 716                          {
 717                                  if((HAL_GetTick()-tickstart) >= Timeout){
 718                                          return 1;
 719                                  }
 720                                  IWDG->KR = IWDG_KEY_REFRESH;                    
 721                          }               
 722                          iVectorConvAcc[0] += HAL_ADC_GetValue(&hadc);
 723                          
 724          
C51 COMPILER V7.50   DVR_BATTERY_LA                                                        09/12/2022 23:28:44 PAGE 13  

 725                          tickstart = HAL_GetTick();              
 726                          IWDG->KR =  IWDG_KEY_REFRESH;           
 727                          while(__HAL_ADC_GET_FLAG(&hadc, ADC_FLAG_EOC) == RESET)
 728                          {
 729                                  if((HAL_GetTick()-tickstart) >= Timeout){
 730                                          return 1;
 731                                  }
 732                                  IWDG->KR = IWDG_KEY_REFRESH;                    
 733                          }               
 734                          iVectorConvAcc[2] += HAL_ADC_GetValue(&hadc);   
 735                          
 736                          tickstart = HAL_GetTick();              
 737                          while(HAL_GetTick()-tickstart>=3)
 738                          {
 739                                  IWDG->KR = IWDG_KEY_REFRESH;                    
 740                          }       
 741                          
 742                  }
 743                  
 744                  for(j=0;j<3;j++){
 745                          IWDG->KR =  IWDG_KEY_REFRESH;
 746                          iVectorConv[j] = iVectorConvAcc[j]/iSampleNumber;
 747                  }
 748                  
 749                  return 0;
 750          }
