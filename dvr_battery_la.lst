 570          /*
 571          */
 572          void vDriver_Backlight_Source(unsigned char bStatus_Volt){
 573                  
 574                  if(bStatus_Volt != SOURCE_ADAPTER && !stScaleParam.sUsbConected){
 575                          if(srFlagScale.bEliminadorOn == 1){
 576                                  if(bStatus_Volt != SOURCE_BATTERY_HIGH){
 577                                          OffBackLight;
 578                                          srFlagScale.bEliminadorOn = 0;
 579                                  }else if(bStatus_Volt == SOURCE_BATTERY_HIGH && stScaleParam.iShowHighBat == 0){
 580                                          OffBackLight;
 581                                          srFlagScale.bEliminadorOn = 0;
 582                                  }
 583                          }               
 584                  }else{
 585                          if(eAccionScale == ScaleRun || eAccionScale == ScaleBattery || srFlagScale.bCalidadTest == 1){                  
 586                                  if(srFlagScale.bEliminadorOn == 0){
 587                                          srFlagScale.bBateriaLow = 0;
 588                                          srFlagScale.bEliminadorOn = 1;
 589                                          OnBackLight;
 590                                  }
 591                          }
 592                  }
 593          }
