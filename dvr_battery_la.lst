 546                                  }else if(fTempfVoltage_Battery < 4.80){
 547                                          iPercentVoltageChargerSet = 6;
 548                                          iGetValueMaxBattery = 0;
 549                                  }else if(fTempfVoltage_Battery < 4.85 && iGetValueMaxBattery == 0){
 550                                          iPercentVoltageChargerSet = 3;
 551                                  }else{
 552                                          iPercentVoltageChargerSet = 0;
 553                                          iGetValueMaxBattery = 1;
 554                                  }
 555                          }else{
 556                                  iPercentVoltageChargerSet = 0;
 557                                  iGetValueMaxBattery = 0;
 558                          }
 559          }
