              void driver_symbol_init(){
                              
                                      if(fVoltage_Battery>=4.0)
                              {
                                      estado=3;
                              }else if(fVoltage_Battery<4.0 && fVoltage_Battery>=3.86)
                              {
                                      estado=2;
                              }else if(fVoltage_Battery<3.86 && fVoltage_Battery>=3.6)
                              {
                                      estado=1;
                              }else if(fVoltage_Battery<3.6)
                              {
                                      estado=0;
                              }
              }
              
              /*
              */
              
