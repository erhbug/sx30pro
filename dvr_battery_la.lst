 482          void vGet_Volts_System(void){
 483                  
 484                  P0|= (1<<5);
 485                  fVoltage_Battery = convertidorADC()*(3.3/255);
 486                  if(fVoltage_Battery > LOW_VOLTAGE_ADAPTER){
 487                          fVoltage_Conector = fVoltage_Battery;
 488                          fVoltage_Battery = 4.6; 
 489                  }else{
 490                          fVoltage_Conector =4.0; 
 491                  }
 492          
 493          
 494          }
