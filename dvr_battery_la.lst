 499          unsigned int convertidorADC(){
 500          
 501          unsigned int v=0;
 502          SARCON = 0x09;
 503                  if(!(SARCON & 0x04))
 504                  {
 505                          SARCON |= 0x04;
 506                          while(SARCON & 0x04)
 507                          {
 508                          }
 509                  }
 510          v=SARDATA;
 511          SARCON &= 0xf7;
 512          return v;
 513          
 514          }
